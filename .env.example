# Copy this file to .env and fill in your values
# Never commit .env — it is in .gitignore

# Anthropic API key for AI-assisted eligibility filtering and answer selection
ANTHROPIC_API_KEY=sk-ant-...

# Path to your resume PDF
JOB_BOT_RESUME_PATH=/path/to/your/resume.pdf

# Optional: path to a vendor/trusted-company whitelist (.xlsx)
JOB_BOT_VENDOR_WORKBOOK_PATH=/path/to/White_Vendors_List.xlsx

# Config files (defaults to ./config/ — only set if you move them)
# JOB_BOT_PROFILE_PATH=./config/candidate_profile.json
# JOB_BOT_QUESTION_ANSWERS_PATH=./config/question_answers.json
# JOB_BOT_INDEED_SEARCH_PATH=./config/indeed_search.json
# JOB_BOT_JOB_URLS_PATH=./config/job_urls.txt

# Output directory for run results
JOB_BOT_OUTPUT_DIR=./runs

# Behavior
JOB_BOT_HEADLESS=true
JOB_BOT_SUBMIT_MODE=auto        # auto | review
JOB_BOT_RECENCY_HOURS=24
JOB_BOT_TIMEOUT_MS=30000
JOB_BOT_DELAY_MS=1500
JOB_BOT_MANUAL_GATE_TIMEOUT_MS=180000

# Chrome MCP bridge (for LinkedIn Easy Apply via logged-in Chrome)
JOB_BOT_CHROME_MCP_HOST=127.0.0.1
JOB_BOT_CHROME_MCP_PORT=8765
